rules_version = '2';

// =====================================================================
// Regras de segurança — Select Australia To-Do
// =====================================================================
// Como aplicar:
//   1. Firebase Console -> Firestore Database -> separador "Rules"
//   2. Cola TODO este conteúdo por cima do que estiver lá
//   3. Clica em "Publish"
//
// O que isto faz:
//   - Só os 3 emails da equipa (com login Google) podem ler/escrever.
//   - Qualquer outra conta é bloqueada, mesmo com login Google válido.
//   - Fecha o buraco do "Modo de Teste" (aberto ao mundo).
//
// Para adicionar/remover membros: edita a lista de emails abaixo e
// volta a fazer "Publish".
// =====================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    match /tasks/{taskId} {
      allow read, write: if request.auth != null &&
        request.auth.token.email in [
          "admin@ibercup.com.au",
          "luccas@ibercup.com.au",
          "jonas@ibercup.com.au"
        ];
    }

    // Tudo o resto fica bloqueado por defeito.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
